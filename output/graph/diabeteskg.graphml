  <data key="d9">HP:0000819</data>
  <data key="d10">Diabetes mellitus</data>
  <data key="d11">A group of abnormalities characterized by hyperglycemia and glucose intolerance.</data>
  <data key="d1">Phenotype</data>
  <data key="d2">Diabetes mellitus</data>
</node>
<node id="Phenotype:HP:0000831">
  <data key="d9">HP:0000831</data>
  <data key="d10">Insulin-resistant diabetes mellitus</data>
  <data key="d11">A type of diabetes mellitus related not to lack of insulin but rather to lack of response to insulin on the part of the target tissues of insulin such as muscle, fat, and liver cells. This type of diabetes is typically associated with increases both in blood glucose concentrations as well as in fast</data>
  <data key="d12">Insulin resistant diabetes|Insulin-resistant diabetes|Insulin resistant diabetes mellitus</data>
  <data key="d1">Phenotype</data>
  <data key="d2">Insulin-resistant diabetes mellitus</data>
</node>
<node id="Phenotype:HP:0001953">
  <data key="d9">HP:0001953</data>
  <data key="d10">Diabetic ketoacidosis</data>
  <data key="d11">A type of diabetic metabolic abnormality with an accumulation of ketone bodies.</data>
  <data key="d12">Diabetic ketosis</data>
  <data key="d1">Phenotype</data>
  <data key="d2">Diabetic ketoacidosis</data>
</node>
<node id="Phenotype:HP:0004904">
  <data key="d9">HP:0004904</data>
  <data key="d10">Maturity-onset diabetes of the young</data>
  <data key="d11">The term Maturity-onset diabetes of the young (MODY) was initially used for patients diagnosed with fasting hyperglycemia that could be treated without insulin for more than two years, where the initial diagnosis was made at a young age (under 25 years). Thus, MODY combines characteristics of type 1</data>
  <data key="d12">Maturity onset diabetes of the young|MODY</data>
  <data key="d1">Phenotype</data>
  <data key="d2">Maturity-onset diabetes of the young</data>
</node>
<node id="Phenotype:HP:0005978">
  <data key="d9">HP:0005978</data>
  <data key="d10">Type II diabetes mellitus</data>
  <data key="d11">A type of diabetes mellitus initially characterized by insulin resistance and hyperinsulinemia and subsequently by glucose interolerance and hyperglycemia.</data>
  <data key="d12">Diabetes mellitus, noninsulin-dependent|Diabetes mellitus type 2|Type II diabetes|Type 2 diabetes|Diabetes mellitus Type II|NIDDM|NIDDM diabetes mellitus|Noninsulin dependent diabetes mellitus|Noninsulin-dependent diabetes mellitus|Noninsulin-dependent diabetes|Non-insulin dependent diabetes</data>
  <data key="d1">Phenotype</data>
  <data key="d2">Type II diabetes mellitus</data>
</node>
<node id="Phenotype:HP:0100651">
  <data key="d9">HP:0100651</data>
  <data key="d10">Type I diabetes mellitus</data>
  <data key="d11">A chronic condition in which the pancreas produces little or no insulin. Type I diabetes mellitus is manifested by the sudden onset of severe hyperglycemia with rapid progression to diabetic ketoacidosis unless treated with insulin.</data>
  <data key="d12">Juvenile diabetes mellitus|Type I diabetes|Insulin-dependent diabetes mellitus|Type 1 diabetes|Diabetes mellitus Type I</data>
  <data key="d1">Phenotype</data>
  <data key="d2">Type I diabetes mellitus</data>
</node>
